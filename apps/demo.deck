-- demo.deck — Deck 3.0 conformance hard-final test (combinatorial stress)
--
-- Purpose: exercise every edge of the language and platform specs in a
-- single loadable application, AND push the combinatorial interactions
-- between features to their limits. If this file parses, type-checks, and
-- runs to its `ALL_PASS` sentinel without panic, the implementation
-- conforms to Deck 3.0 not just at the per-feature level but also at the
-- feature-interaction level.
--
-- Logic is deliberately nonsensical — the goal is breadth-times-depth
-- coverage, not application realism.
--
-- Sections (each ends with `log.info("PASS:section_X")`):
--   A. Identity + needs + grants
--   B. Assets + migrations + config (every allowed type)
--   C. Type declarations + parametric instantiation + recursion
--   D. Error domain declarations + universals + cross-domain bridging
--   E. Functions (pure, impure, private, recursive, mutual, HOF, closures)
--   F. Builtin sampling — every module exercised, including edge cases
--   G. Pattern matching — every form + deep nesting + guards + exhaustiveness
--   H. Bindings + destructuring (tuple, named tuple, cons, record, with chain)
--   I. Service consumption (one per tier; both required and optional)
--   J. Stream combinators (filter, map, throttle, distinct, scan, combine,
--      merge, window, buffer, take_while, debounce) + named sources
--   K. Machine with all transition forms + composition + payload + cascades
--   L. Reactive @on watch + lifecycle hooks + cascading effects
--   M. Timers (@on every / @on after with all interval ranges)
--   N. OS event subscription + multi-pattern + payload binders
--   O. Service provider — query, mutation, action stream, watch stream, handle
--   P. Deep links (@handles + @on open_url with multiple patterns)
--   Q. Content body — every primitive AND every nesting combination
--      (for-in-when-in-list, form with nested groups, conditional renders)
--   R. Combinatorial stress sections:
--      S1. Deeply nested pattern matching (Tree × Status × Optional)
--      S2. Recursive type traversal (Tree depth 6, fold/sum/max)
--      S3. HOF chains with closures capturing locals
--      S4. String interpolation extreme (nested + multi-line + escape)
--      S5. Long pipe chains (8+ operators in one expression)
--      S6. Stream combinator stress
--      S7. Config rotation through every type + change events
--      S8. TCO recursion to depth 1000+ (factorial, countdown, mutual)
--      S9. Map/list size stress (200-element processing)
--      S10. Result/Option chains with map_err at every layer
--      S11. Cascading transitions (entry hook fires next event)
--      S12. Error recovery chain (5-layer fallback)
--      S13. Content body extreme nesting (3 levels of for/when/list)
--      S14. Service self-call chain (this app calls its own service)
--      S15. with{} chain on nested records (3 levels)
--   T. Final sentinel: ALL_PASS:demo.conformance

------------------------------------------------------------------------
-- A · Identity + needs + grants
------------------------------------------------------------------------

@app
  name:        "Deck 3.0 Conformance Demo"
  id:          "deck.conformance.demo"
  version:     "1.0.0"
  edition:     2027
  entry:       App
  icon:        "DM"
  tags:        ["conformance", "test", "demo"]
  author:      "diana"
  license:     :mit
  orientation: :any
  log_level:   :info
  serves:
    - "deck.conformance.demo/echo"

@needs
  deck_level: 3
  deck_os:    ">= 1"
  runtime:    ">= 1.0"
  max_heap:   192KB
  max_stack:  512
  caps:
    notifications: optional
  services:
    "storage.fs":          ">= 1"
    "storage.nvs":         ">= 1"
    "storage.cache":       ">= 1"
    "network.http":        optional
    "network.ws":          optional
    "network.wifi":        optional
    "network.bluetooth":   optional
    "system.platform":     ">= 1"
    "system.apps":         optional
    "system.power":        optional
    "system.display":      optional
    "system.audio":        optional
    "system.security":     optional
    "system.time":         optional
    "system.locale":       optional
    "system.ota":          optional
    "system.url":          ">= 1"
    "system.notify":       optional
    "system.theme":        optional
    "system.logs":         ">= 1"
    "system.scheduler":    ">= 1"
    "system.events":       ">= 1"
    "system.intents":      ">= 1"
    "system.services":     ">= 1"
    "system.tasks":        optional
    "api.client":          optional
    "media.image":         optional
    "media.audio":         optional
    "auth.oauth":          optional
    "data.cache":          optional
    "share.target":        optional

@grants
  services.fs:
    reason: "Persist demo artefacts."
    prompt: :at_install
    paths:  ["/sd/demo/"]
  services.nvs:
    reason: "Store demo bookmarks."
    prompt: :at_install
  services.http:
    reason: "Demo HTTP probe."
    prompt: :at_install
    allowed_hosts: ["demo.example.com"]
  services.ws:
    reason: "Demo WebSocket probe."
    prompt: :at_install
    allowed_hosts: ["demo.example.com"]
  services.wifi:
    reason: "Demo Wi-Fi probe."
    prompt: :at_install
  services.ble:
    reason: "Demo BLE probe."
    prompt: :at_install
  services.apps:
    reason: "Read installed app registry."
    prompt: :at_install
  services.sec:
    reason: "Read permission state."
    prompt: :at_install
  services.systime:
    reason: "Demo wall-clock probe."
    prompt: :at_install
  services.locale:
    reason: "Demo locale probe."
    prompt: :at_install
  services.ota:
    reason: "Demo OTA probe."
    prompt: :at_install
  services.url:
    reason: "Demo deep-link probe."
    prompt: :at_install
  services.notify:
    reason: "Show progress toasts."
    prompt: :on_first_use
  services.theme:
    reason: "Demo theme probe."
    prompt: :at_install
  services.tasks:
    reason: "Demo per-process probe."
    prompt: :at_install
  services.api:
    reason: "Talk to the demo API."
    prompt: :at_install
    allowed_hosts: ["demo.example.com"]
  services.image:
    reason: "Cache demo thumbnails."
    prompt: :at_install
    allowed_hosts: ["demo.example.com"]
  services.media_audio:
    reason: "Demo audio playback."
    prompt: :on_first_use
  services.oauth:
    reason: "Demo OAuth flow."
    prompt: :at_install
  services.share:
    reason: "Demo share-to flow."
    prompt: :on_first_use
  logging:
    persist: true

------------------------------------------------------------------------
-- B · Assets + migrations + config
------------------------------------------------------------------------

@assets
  icon       : "assets/demo_icon.png"          as: :icon
  splash     : "assets/demo_splash.png"
  ca_demo    : "assets/demo_ca.crt"            as: :tls_cert  for_domain: "demo.example.com"
  remote_doc : download: "https://demo.example.com/doc.json"  ttl: 7d

@migrate
  from 0:
    nvs.set_int("schema_version", 1)
  from 1:
    nvs.set_str("greeting", "hello v2")
  from 2:
    let old = nvs.get_str("legacy_key")
    match old
      | :ok v -> nvs.set_str("greeting", v)
      | :err _ -> unit

@config
  greeting     : str         = "hello world"
  retry_count  : int         = 3      min: 0  max: 10
  pi_estimate  : float       = 3.14
  enabled      : bool        = true
  theme        : atom        = :auto
  sync_every   : Duration    = 5m
  cache_quota  : Size        = 64KB
  api_token    : str?        = :none
  pinned_ids   : [str]       = []
  bookmarks    : {str: str}  = {}
  history      : {str: Timestamp} = {}

------------------------------------------------------------------------
-- C · Type declarations
------------------------------------------------------------------------

@type Author
  did          : str
  handle       : str
  display_name : str?
  followers    : int

@type Post
  uri        : str
  author     : Author
  text       : str
  likes      : int
  created_at : Timestamp

@type Pair (A, B)
  fst : A
  snd : B

@type Tree =
  | :leaf
  | :node (left: Tree, right: Tree, value: int)

@type Status =
  | :idle
  | :active (temp: float, max: float)
  | :error (reason: str)
  | :legacy 42
  | :timed (at: Timestamp, count: int)

@type Empty

@type LinkedList (T) =
  | :nil
  | :cons (head: T, tail: LinkedList T)

------------------------------------------------------------------------
-- D · Error domain declarations
------------------------------------------------------------------------

@errors demo
  :bad_input    "Caller sent an invalid argument"
  :over_limit   "Value exceeded the demo's internal cap"
  :unsupported  "Operation not implemented in this demo build"

@errors echo                   -- for the @service below
  :unavailable
  :permission_denied
  :service_unavailable
  :timeout
  :empty
  :too_long

------------------------------------------------------------------------
-- E · Pure, impure, private functions (every annotation style)
------------------------------------------------------------------------

@private fn _double (x: int) -> int =
  x * 2

fn add (a: int, b: int) -> int =
  a + b

fn add_three (a: int, b: int, c: int) -> int =
  let s1 = a + b
  let s2 = s1 + c
  s2

fn quadratic_roots (a: float, b: float, c: float) -> Result (float, float) demo.Error =
  let disc = b * b - 4.0 * a * c
  if disc < 0.0
    then :err :bad_input
    else
      let s = math.sqrt(disc)
      let two_a = 2.0 * a
      :ok ((-b + s) / two_a, (-b - s) / two_a)

fn safe_div (a: int, b: int) -> int? =
  if b == 0 then :none else :some (a / b)

fn map_squared (xs: [int]) -> [int] =
  list.map(xs, x -> x * x)

fn each_log (xs: [int]) -> unit ! =
  list.each_io(xs, x -> log.debug("item={x}"))

fn fetch_thing () -> Result int demo.Error ! =
  let raw = nvs.get_int("answer") |> result.map_err(_ -> :unsupported)?
  :ok raw

fn impure_with_result (k: str) -> Result str demo.Error ! =
  match nvs.get_str(k)
    | :ok v               -> :ok v
    | :err :not_found     -> :err :unsupported
    | :err _              -> :err :over_limit

fn higher_order (xs: [int], f: (int) -> int) -> [int] =
  list.map(xs, f)

fn higher_order_io (xs: [int], f: (int) -> unit !) -> unit ! =
  list.each_io(xs, f)

fn factorial (n: int) -> int =
  if n <= 1 then 1 else n * factorial(n - 1)

fn count_down (n: int, acc: [int]) -> [int] =
  if n == 0 then list.reverse(acc) else count_down(n - 1, list.prepend(acc, n))

------------------------------------------------------------------------
-- F · Builtin sampling — exercise every module from BUILTINS.md
------------------------------------------------------------------------

fn run_builtin_sweep () -> bool ! =
  -- ─── math (full) ───
  let m_ok =
    math.abs_int(-5) == 5
      and math.min_int(2, 5) == 2
      and math.max_int(2, 5) == 5
      and math.clamp_int(15, 0, 10) == 10
      and math.sign_int(-3) == -1
      and math.gcd(12, 18) == 6
      and math.lcm(4, 6) == 12
      and math.pow_int(2, 10) == 1024
      and math.abs(-2.5) == 2.5
      and math.floor(3.7) == 3.0
      and math.ceil(3.2) == 4.0
      and math.round(3.7, :none) == 4.0
      and math.round(3.456, :some 2) == 3.46
      and math.sign(-1.5) == -1.0
      and math.min(1.0, 2.0) == 1.0
      and math.max(1.0, 2.0) == 2.0
      and math.clamp(2.5, 0.0, 1.0) == 1.0
      and math.lerp(0.0, 10.0, 0.5) == 5.0
      and math.sqrt(16.0) == 4.0
      and math.pow(2.0, 3.0) == 8.0
      and math.exp(0.0) == 1.0
      and math.is_zero(math.sin(0.0))
      and math.cos(0.0) == 1.0
      and math.tan(0.0) == 0.0
      and math.atan2(1.0, 1.0) > 0.0
      and math.to_radians(180.0) > 3.14
      and math.to_degrees(math.pi) > 179.0
      and math.is_finite(1.0)
      and math.pi > 3.14 and math.pi < 3.15
      and math.tau > 6.28
      and math.e > 2.71
      and math.max_int > 0

  -- ─── text (full) ───
  let t_ok =
    text.len("hello") == 5
      and text.chars("héllo") >= 5
      and text.is_empty("") and not text.is_empty("x")
      and text.is_blank("   ")
      and text.starts("hello", "he") and text.ends("hello", "lo")
      and text.contains("hello world", "lo wo")
      and text.index_of("hello", "ll") == :some 2
      and text.last_index_of("hello", "l") == :some 3
      and text.count("aaaa", "aa") == 2
      and text.eq_i("ABC", "abc")
      and text.slice("hello", 1, 4) == "ell"
      and text.substring("hello", 1, 3) == "ell"
      and text.trim("  hi  ") == "hi"
      and text.trim_start("  hi") == "hi"
      and text.trim_end("hi  ") == "hi"
      and text.upper("abc") == "ABC"
      and text.lower("ABC") == "abc"
      and text.reverse("abc") == "cba"
      and text.repeat("ab", 3) == "ababab"
      and text.replace("hello", "l", "L") == "heLLo"
      and text.replace_once("hello", "l", "L") == "heLlo"
      and text.pad_left("7", 3, "0") == "007"
      and text.pad_right("7", 3, "0") == "700"
      and list.len(text.split("a,b,c", ",")) == 3
      and list.len(text.split_lines("a\nb\nc")) == 3
      and text.join(["a", "b", "c"], "-") == "a-b-c"
      and text.parse_int("42") == :some 42
      and text.parse_int("nope") == :none
      and text.parse_float("3.14") == :some 3.14
      and text.parse_bool("true") == :some true
      and text.b64_encode("hi") == "aGk="
      and text.url_encode(" ") == "%20"
      and text.hex_encode("A") == "41"

  -- ─── list (full) ───
  let l_ok =
    list.len(list.empty()) == 0
      and list.len(list.repeat(0, 5)) == 5
      and list.len(list.range(0, 10)) == 10
      and list.len(list.range_step(0, 10, 2)) == 5
      and list.len([1, 2, 3]) == 3
      and not list.is_empty([1])
      and list.head([1, 2, 3]) == :some 1
      and list.last([1, 2, 3]) == :some 3
      and list.nth([1, 2, 3], 1) == :some 2
      and list.nth([1, 2, 3], 99) == :none
      and list.contains([1, 2, 3], 2)
      and list.index_of([1, 2, 3], 2) == :some 1
      and list.len(list.take([1, 2, 3, 4, 5], 3)) == 3
      and list.len(list.drop([1, 2, 3, 4, 5], 2)) == 3
      and list.len(list.slice([1, 2, 3, 4, 5], 1, 4)) == 3
      and list.len(list.map([1, 2, 3], x -> x * 2)) == 3
      and list.len(list.filter([1, 2, 3, 4], x -> x > 2)) == 2
      and list.reduce([1, 2, 3, 4], 0, (acc, x) -> acc + x) == 10
      and list.len(list.flat_map([1, 2], x -> [x, x])) == 4
      and list.find([1, 2, 3], x -> x > 1) == :some 2
      and list.any([1, 2, 3], x -> x > 2)
      and list.all([1, 2, 3], x -> x > 0)
      and list.len(list.concat([1, 2], [3, 4])) == 4
      and list.len(list.append([1, 2], 3)) == 3
      and list.len(list.prepend([2, 3], 1)) == 3
      and list.len(list.zip([1, 2, 3], ["a", "b"])) == 2
      and list.len(list.reverse([1, 2, 3])) == 3
      and list.len(list.distinct([1, 1, 2, 2, 3])) == 3
      and list.len(list.sort([3, 1, 2])) == 3
      and list.len(list.sort_by([3, 1, 2], x -> -x)) == 3
      and list.len(list.chunks([1, 2, 3, 4, 5], 2)) == 3

  -- ─── map (full) ───
  let p = map.set(map.empty(), "a", 1)
  let p2 = map.set(p, "b", 2)
  let p3 = map.set(p2, "c", 3)
  let mp_ok =
    map.len(p3) == 3
      and not map.is_empty(p3)
      and map.has(p3, "b")
      and map.get(p3, "a") == :some 1
      and map.get_or(p3, "missing", 99) == 99
      and list.len(map.keys(p3)) == 3
      and list.len(map.values(p3)) == 3
      and list.len(map.entries(p3)) == 3
      and map.len(map.delete(p3, "a")) == 2
      and map.len(map.merge(p3, map.set(map.empty(), "d", 4))) == 4
      and map.len(map.filter(p3, (k, v) -> v > 1)) == 2
      and map.len(map.map(p3, (k, v) -> v * 2)) == 3
      and map.len(map.from_pairs([("x", 1), ("y", 2)])) == 2

  -- ─── bytes (full) ───
  let b = bytes.from_str("hello", :utf8)
  let by_ok =
    bytes.len(b) == 5
      and bytes.eq(b, bytes.from_str("hello", :utf8))
      and bytes.len(bytes.slice(b, 1, 4)) == 3
      and bytes.len(bytes.concat([b, b])) == 10
      and bytes.at(b, 0) == :some 104     -- 'h'
      and bytes.at(b, 99) == :none
      and bytes.starts(b, bytes.from_str("he", :utf8))
      and bytes.ends(b, bytes.from_str("lo", :utf8))
      and bytes.to_hex(b) == "68656c6c6f"
      and bytes.to_b64(b) == "aGVsbG8="
      and bytes.to_b64url(b) == "aGVsbG8"
      and (match bytes.to_str(b, :utf8) | :ok s -> s == "hello" | :err _ -> false)
      and (match bytes.from_hex("68") | :ok x -> bytes.len(x) == 1 | :err _ -> false)
      and (match bytes.from_b64("aGk=") | :ok x -> bytes.len(x) == 2 | :err _ -> false)

  -- ─── option (full) ───
  let opt_ok =
    option.is_some(option.some(1))
      and option.is_none(option.none())
      and option.unwrap_or(:none, 42) == 42
      and option.unwrap_or(:some 7, 0) == 7
      and option.unwrap_or_else(:none, () -> 99) == 99
      and (match option.map(:some 5, x -> x * 2) | :some 10 -> true | _ -> false)
      and (match option.and_then(:some 5, x -> :some (x + 1)) | :some 6 -> true | _ -> false)
      and (match option.or_else(:none, () -> :some 5) | :some 5 -> true | _ -> false)
      and (match option.filter(:some 5, x -> x > 0) | :some 5 -> true | _ -> false)
      and (match option.filter(:some 5, x -> x > 99) | :none -> true | _ -> false)

  -- ─── result (full) ───
  let r_ok =
    result.is_ok(:ok 5)
      and result.is_err(:err :bad_input)
      and result.unwrap_or(:err :bad_input, 99) == 99
      and result.unwrap_or_else(:err :bad_input, e -> 7) == 7
      and (match result.to_option(:ok 5) | :some 5 -> true | _ -> false)
      and (match result.to_option(:err :x) | :none -> true | _ -> false)
      and (match result.map(:ok 5, x -> x + 1) | :ok 6 -> true | _ -> false)
      and (match result.map_err(:err :a, e -> :b) | :err :b -> true | _ -> false)
      and (match result.and_then(:ok 5, x -> :ok (x * 2)) | :ok 10 -> true | _ -> false)
      and (match result.or_else(:err :a, e -> :ok 1) | :ok 1 -> true | _ -> false)

  -- ─── json (full) ───
  let j_ok =
    (match json.parse("[1, 2, 3]") | :ok v -> type_of(v) == :list | :err _ -> false)
      and (match json.parse("{\"a\": 1}") | :ok v -> type_of(v) == :map | :err _ -> false)
      and (match json.parse("\"x\"") | :ok v -> type_of(v) == :str | :err _ -> false)
      and (match json.parse("42") | :ok v -> type_of(v) == :int | :err _ -> false)
      and (match json.parse("true") | :ok v -> type_of(v) == :bool | :err _ -> false)
      and (match json.parse("not json") | :err :malformed -> true | _ -> false)
      and (match json.encode([1, 2, 3]) | :ok s -> text.len(s) > 0 | :err _ -> false)
      and (match json.encode_pretty({ "a": 1 }) | :ok s -> text.contains(s, "\n") | :err _ -> false)

  -- ─── time (full pure + impure) ───
  let now1 = time.now()
  let mono = time.monotonic()
  let later = time.add(now1, 5m)
  let earlier = time.sub(now1, 5m)
  let dp = time.date_parts(now1)
  let durp = time.duration_parts(5m + 30s)
  let ti_ok =
    now1 > 0
      and mono > 0
      and time.before(earlier, later)
      and time.after(later, earlier)
      and time.diff(later, now1) == 5m
      and time.start_of_day(now1) <= now1
      and (match time.day_of_week(now1)
            | :monday -> true | :tuesday -> true | :wednesday -> true
            | :thursday -> true | :friday -> true | :saturday -> true | :sunday -> true)
      and dp.year > 1970
      and durp.minutes == 5
      and durp.seconds == 30
      and text.len(time.duration_str(5m)) > 0
      and text.len(time.ago(now1)) > 0
      and text.contains(time.to_iso(now1), "T")
      and (match time.from_iso("2027-01-01T00:00:00Z") | :ok _ -> true | :err _ -> false)
      and (match time.format(now1, "YYYY-MM-DD") | :ok s -> text.len(s) == 10 | :err _ -> false)
      and (match time.parse("2027-01-01", "YYYY-MM-DD") | :ok _ -> true | :err _ -> false)
      and (match time.from_iso("not a date") | :err :malformed -> true | _ -> false)

  -- ─── rand (full) ───
  let r1 = rand.int(0, 10)
  let r2 = rand.float()
  let r3 = rand.bool(:some 0.5)
  let r4 = rand.choice([1, 2, 3])
  let r5 = rand.shuffle([1, 2, 3, 4, 5])
  let r6 = rand.uuid()
  let r7 = rand.bytes(8)
  let r8 = rand.range(0.0, 1.0)
  let rd_ok =
    r1 >= 0 and r1 < 10
      and r2 >= 0.0 and r2 < 1.0
      and (r3 == true or r3 == false)
      and (match r4 | :some _ -> true | :none -> false)
      and list.len(r5) == 5
      and text.len(r6) == 36       -- UUID v4 standard length
      and bytes.len(r7) == 8
      and r8 >= 0.0 and r8 < 1.0
      and (match rand.choice([]) | :none -> true | _ -> false)

  -- ─── record (full) ───
  let post = sample_post()
  let rec_ok =
    list.len(record.keys(post)) == 5
      and record.has_field(post, :likes)
      and not record.has_field(post, :nonexistent)
      and (match record.field(post, :likes) | :some 99 -> true | _ -> false)
      and (match record.field(post, :missing) | :none -> true | _ -> false)
      and map.len(record.to_map(post)) == 5

  -- ─── type_of (every shape) ───
  let typ_ok =
    type_of(42) == :int
      and type_of(3.14) == :float
      and type_of(true) == :bool
      and type_of("hi") == :str
      and type_of(:foo) == :atom
      and type_of(unit) == :unit
      and type_of([1]) == :list
      and type_of({ "a": 1 }) == :map
      and type_of((1, 2)) == :tuple
      and type_of((x: 1, y: 2)) == :named_tuple
      and type_of(:some 1) == :optional
      and type_of(rand.bytes(1)) == :bytes
      and type_of(x -> x) == :fn
      and type_of(post) == :Post

  -- ─── stream operators (composability — exercised in @on source below) ───
  -- Stream operators exercised live in §J via @on source pipelines.
  -- This sweep verifies they exist as builtins by composing without subscribing:
  -- (we cannot bind a Stream to a let; per §2.7 Stream is substructural)
  -- Composition presence is verified at parse time.

  -- ─── log (smoke; impure) ───
  log.trace("trace", :some { "k": "v" })
  log.debug("debug")
  log.peek("peek_label", 42)

  m_ok and t_ok and l_ok and mp_ok and by_ok and opt_ok and r_ok and j_ok
    and ti_ok and rd_ok and rec_ok and typ_ok

------------------------------------------------------------------------
-- G · Pattern matching — every form
------------------------------------------------------------------------

fn pat_literal (x: int) -> str =
  match x
    | 0  -> "zero"
    | 1  -> "one"
    | _  -> "many"

fn pat_atom (s: Status) -> str =
  match s
    | :idle                       -> "idle"
    | :active (temp: t, max: m)   -> "active {t}/{m}"
    | :error (reason: r)          -> "error: {r}"
    | :legacy v                   -> "legacy {v}"
    | :timed (at: ts, count: c)   -> "timed {ts} x{c}"

fn pat_record (p: Post) -> str =
  match p
    | Post { likes: 0 }                       -> "no likes"
    | Post { likes: n } when n > 100          -> "viral: {n}"
    | Post { author: a, likes: n }            -> "{a.handle} ({n})"

fn pat_tuple (t: (int, int, int)) -> int =
  match t
    | (0, 0, 0)         -> 0
    | (a, b, c)         -> a + b + c

fn pat_named_tuple (n: (x: int, y: int)) -> int =
  match n
    | (x: 0, y: 0)      -> 0
    | (x, y)            -> x + y

fn pat_list (xs: [int]) -> str =
  match xs
    | []                -> "empty"
    | [a]               -> "one: {a}"
    | [a, b]            -> "two: {a} {b}"
    | [h, ...t]         -> "head {h} + {list.len(t)} more"

fn pat_nested (val: any) -> str =
  match val
    | :ok (:some n)     -> "double-wrap {n}"
    | :ok :none         -> "ok-none"
    | :err e            -> "error {e}"
    | _                 -> "other"

fn pat_guard (n: int) -> str =
  match n
    | x when x < 0      -> "negative"
    | x when x == 0     -> "zero"
    | x when x < 10     -> "small"
    | _                 -> "big"

------------------------------------------------------------------------
-- H · Bindings + destructuring
------------------------------------------------------------------------

fn destructure_demo () -> int =
  let (a, b)         = (10, 20)
  let (x: px, y: py) = (x: 100, y: 200)
  let (h2, h3)       = (h: 7, h2: 8, h3: 9)
                       |> _ -> (8, 9)              -- pure trick: discard then return tuple
  let [first, ...rest] = [1, 2, 3, 4]
  let Post { likes: lk, author: au } = sample_post()
  a + b + px + py + first + list.len(rest) + lk

@private fn sample_post () -> Post =
  Post {
    uri:        "demo://post/1",
    author:     Author { did: "did:plc:demo", handle: "demo.bsky", display_name: :some "Demo", followers: 42 },
    text:       "hello demo",
    likes:      99,
    created_at: 0
  }

fn field_shorthand_demo () -> Post =
  let uri        = "demo://post/2"
  let likes      = 5
  let author     = Author { did: "did:plc:b", handle: "b", display_name: :none, followers: 0 }
  let text       = "shorthand"
  let created_at = 0
  Post { uri, author, text, likes, created_at }

fn with_postfix_demo () -> Post =
  sample_post() with { likes: 999, text: "updated" }

------------------------------------------------------------------------
-- I · Service consumption — one per tier
------------------------------------------------------------------------

@use
  storage.fs          as fs
  storage.nvs         as nvs
  storage.cache       as cache
  network.http        as http
  network.ws          as ws
  network.wifi        as wifi
  network.bluetooth   as ble
  system.platform     as platform
  system.apps         as apps
  system.power        as power
  system.display      as display
  system.audio        as audio
  system.security     as sec
  system.time         as systime
  system.locale       as locale
  system.ota          as ota
  system.url          as url
  system.notify       as notify
  system.theme        as theme
  system.logs         as logs
  system.scheduler    as scheduler
  system.events       as events
  system.intents      as intents
  system.services     as services
  system.tasks        as tasks
  api.client          as api
    base_url: "https://demo.example.com"
    timeout:  10s
    retry:    1
  media.image         as image
  media.audio         as media_audio
  auth.oauth          as oauth
  data.cache          as data_cache
  service "share.target"                as share
  service "deck.conformance.demo/echo"  as self_echo

fn try_each_tier () -> bool ! =
  -- Tier 1 — storage
  let _ = nvs.set_str("demo_key", "demo_val")
  let _ = nvs.get_str("demo_key")
  let _ = cache.set("hot", "data", 30s)
  let _ = cache.get("hot")
  let _ = fs.exists("/sd/demo/probe.txt")

  -- Tier 3 — system
  let info = platform.versions()
  log.info("platform os={info.os} dl={info.deck_level}")

  -- Tier 4 — high-level (optional services; degrade gracefully)
  match api.get("/probe")
    | :ok _              -> log.info("api ok")
    | :err :unavailable  -> log.info("api unavailable; ok")
    | :err _             -> log.info("api error; ok")

  match image.load("https://demo.example.com/i.png")
    | :ok _              -> log.info("image ok")
    | :err :unavailable  -> log.info("image unavailable; ok")
    | :err _             -> log.info("image error; ok")

  match notify.toast("conformance running", :some 1500ms)
    | :ok _              -> log.info("toast ok")
    | :err :unavailable  -> log.info("toast unavailable; ok")
    | :err :permission_denied -> log.info("toast denied; ok")
    | :err _             -> log.info("toast error; ok")

  true

------------------------------------------------------------------------
-- J · Stream consumption — declared in @on source below;
--    here we have a named source we re-read from elsewhere.
------------------------------------------------------------------------

-- (Named source declared at @on level — see §K below: HeapHistory.)

fn read_recent_heap () -> int ! =
  list.len(HeapHistory.recent(5))

------------------------------------------------------------------------
-- K · Machines — every transition form, payload access, composition
------------------------------------------------------------------------

@machine SubMachine
  state :idle
  state :working (job: str)

  initial :idle

  on :start (job: str)
    from :idle
    to :working (job: job)

  on :stop
    from :working _
    to :idle

  state :working
    on enter -> log.info("sub working on {job}")
    on leave -> log.info("sub leaving {job}")

-- §S11 · Cascading transitions: each on-enter fires the next event.
-- Tests that hooks may dispatch and the scheduler interleaves correctly.

@machine Cascade
  state :a
  state :b
  state :c
  state :d
  state :done

  initial :a

  on :go_b
    from :a
    to :b
  on :go_c
    from :b
    to :c
  on :go_d
    from :c
    to :d
  on :finish
    from :d
    to :done

  state :a
    on enter -> log.info("cascade a")
  state :b
    on enter -> Cascade.send(:go_c)
  state :c
    on enter -> Cascade.send(:go_d)
  state :d
    on enter -> Cascade.send(:finish)
  state :done
    on enter ->
      log.info("PASS:section_S11_cascading_transitions")

@machine App
  state :init
  state :counting (n: int)
  state :showing  (label: str, count: int)
  state :nested   machine: SubMachine
  state :rendering
  state :back_demo
  state :final

  initial :init

  on :start
    from :init
    to :counting (n: 0)

  on :tick
    from :counting current
    to :counting (n: current.n + 1)
    when current.n < 3

  on :promote
    from :counting (n: x)
    to :showing (label: "from-counting", count: x)

  on :wildcard_event
    from *
    to :showing (label: "wildcard", count: 0)
    when true

  on :enter_nested
    from :showing _
    to :nested

  on :exit_nested
    from :nested
    to :rendering

  on :show_back
    from *
    to :back_demo

  on :back_to_prev
    from :back_demo
    to previous

  on :finish
    from *
    to :final

  state :init
    on enter -> log.info("init entered")

  state :counting
    on enter -> log.info("counting at n={n}")
    on leave -> log.info("counting leaving")

  state :showing
    on enter -> log.info("showing label={label} count={count}")

  state :rendering
    on enter -> log.info("rendering entered")
    content =
      group "header"
        "Demo conformance render"
        "Running every primitive"

      group "data wrappers"
        media "https://demo.example.com/cover.png"
          alt:  "cover"
          role: :cover
        rich_text "Hello **world** with `code` and [link](https://x)"
        status :ok label: "Healthy"
        progress
          value: 0.42
          label: :some "Loading"
        chart [1.0, 2.0, 3.0, 2.0, 1.0]
          label:   :some "rolling avg"
          x_label: :some "tick"
          y_label: :some "value"
        markdown "## hello\n* one\n* two"
          purpose: :some :reading
          on link -> Compose.send(:open, url: event.url)
        markdown_editor
          value: "draft text"
          on change -> Editor.send(:typed, text: event.value)
          placeholder: :some "type something"

      group "input intents"
        toggle
          name:  :flag
          state: true
          on change -> Editor.send(:toggle, value: event.value)
        range
          name:  :slider
          value: 50
          min:   0
          max:   100
          step:  1
          on change -> Editor.send(:set, value: event.value)
        choice
          name:    :pick
          value:   :a
          options: [(label: "A", value: :a), (label: "B", value: :b)]
          on change -> Editor.send(:choose, value: event.value)
        multiselect
          name:    :pills
          value:   [:a]
          options: [(label: "A", value: :a), (label: "B", value: :b), (label: "C", value: :c)]
          on change -> Editor.send(:multi, values: event.value)
        text
          name:  :title
          value: "default"
          hint:  :some "title here"
          max_length: :some 80
          on change -> Editor.send(:title, value: event.value)
        password
          name:  :pwd
          value: ""
          hint:  :some "password"
          on change -> Editor.send(:pwd, value: event.value)
        pin
          name:  :code
          length: 4
          on complete -> Editor.send(:pin, code: event.value)
        date
          name:  :when
          value: 0
          hint:  :some "date"
          on change -> Editor.send(:date, ts: event.value)
        search
          name:  :q
          value: ""
          hint:  :some "search"
          on change -> Editor.send(:search, q: event.value)

      group "action intents"
        navigate
          label: "Settings"
          badge: :some 3
          -> App.send(:show_back)
        trigger
          label: "Refresh"
          -> App.send(:tick)
        confirm
          label:  "Wipe"
          prompt: "Really wipe?"
          -> App.send(:wildcard_event)
        create
          label: "New"
          -> App.send(:enter_nested)

      group "passive intent"
        share "demo://post/1"
          label: :some "share this"

      group "structural — list"
        list [1, 2, 3]
          on empty -> "no items"
          has_more: false
          on more -> App.send(:tick)
          item ->
            "item {item}"

      group "structural — form"
        form
          on submit -> Editor.send(:submitted, values: event.values)
          submit_label: :some "OK"
          text
            name: :form_field
            value: ""
            on change -> Editor.send(:form_field, value: event.value)

      group "state markers"
        loading
        error reason: "demo error reason"

      group "when + for"
        when true
          "shown"
        when false
          "hidden"
        for n in [1, 2, 3]
          "n={n}"

      -- §S13 · Extreme content body nesting: list × group × for × when × content fn
      group "extreme nesting"
        for p in [sample_post(), field_shorthand_demo(), s15_with_chain()]
          group "post {p.uri}"
            post_card(p)
            when p.likes > 10
              for tag in p.author.handle |> text.split("")
                "tag {tag}"
            when p.likes <= 10
              status :idle label: "low engagement"

        list [1, 2, 3, 4, 5]
          on empty -> "no nums"
          item ->
            group "outer item {item}"
              for inner in list.range(0, item)
                when inner % 2 == 0
                  "even inner: {inner} of outer {item}"
                when inner % 2 != 0
                  "odd inner: {inner} of outer {item}"

        form
          on submit -> Editor.send(:submitted, values: event.values)
          submit_label: :some "OK Nested"
          group "name section"
            text
              name: :first_name
              value: ""
              hint: :some "first"
              on change -> Editor.send(:title, value: event.value)
            text
              name: :last_name
              value: ""
              hint: :some "last"
              on change -> Editor.send(:title, value: event.value)
          group "preferences"
            for opt_name in [:notifications, :sounds, :haptics]
              toggle
                name:  opt_name
                state: true
                on change -> Editor.send(:toggle, value: event.value)
            choice
              name:    :priority
              value:   :normal
              options: [(label: "Low", value: :low), (label: "Normal", value: :normal), (label: "High", value: :high)]
              on change -> Editor.send(:choose, value: event.value)
          when true
            group "conditional inner section"
              "always rendered (when true)"
              progress
                value: 0.5
                label: :some "halfway"

  state :back_demo
    on enter -> log.info("back_demo entered")

  state :final
    on enter -> log.info("final entered")

------------------------------------------------------------------------
-- Editor + Compose machines used in content handlers
------------------------------------------------------------------------

@machine Editor
  state :idle

  initial :idle

  on :typed (text: str)
    from :idle
    to :idle

  on :toggle (value: bool)
    from :idle
    to :idle

  on :set (value: int)
    from :idle
    to :idle

  on :choose (value: atom)
    from :idle
    to :idle

  on :multi (values: [atom])
    from :idle
    to :idle

  on :title (value: str)
    from :idle
    to :idle

  on :pwd (value: str)
    from :idle
    to :idle

  on :pin (code: str)
    from :idle
    to :idle

  on :date (ts: Timestamp)
    from :idle
    to :idle

  on :search (q: str)
    from :idle
    to :idle

  on :form_field (value: str)
    from :idle
    to :idle

  on :submitted (values: {atom: any})
    from :idle
    to :idle

@machine Compose
  state :idle

  initial :idle

  on :open (url: str)
    from :idle
    to :idle

------------------------------------------------------------------------
-- L · Reactive watch + lifecycle hooks (declared as @on)
------------------------------------------------------------------------

@on launch
  log.info("PASS:section_A_to_E")

  -- Section F: builtin coverage
  let r_built = run_builtin_sweep()
  if r_built then log.info("PASS:section_F_builtins") else log.warn("FAIL:section_F_builtins")

  -- Section G: pattern matching
  let r_pat = pat_literal(2) == "many"
                and pat_atom(:idle) == "idle"
                and pat_record(sample_post()) != ""
                and pat_tuple((1, 2, 3)) == 6
                and pat_named_tuple((x: 3, y: 4)) == 7
                and pat_list([1, 2]) == "two: 1 2"
                and pat_nested(:ok (:some 9)) == "double-wrap 9"
                and pat_guard(-1) == "negative"
  if r_pat then log.info("PASS:section_G_patterns") else log.warn("FAIL:section_G_patterns")

  -- Section H: destructuring + with chain
  let _   = destructure_demo()
  let h1  = field_shorthand_demo()
  let h2  = with_postfix_demo()
  if h1.likes == 5 and h2.likes == 999
    then log.info("PASS:section_H_destructuring")
    else log.warn("FAIL:section_H_destructuring")

  -- Section I: per-tier service consumption (subset)
  let r_tier = try_each_tier()
  if r_tier then log.info("PASS:section_I_services") else log.warn("FAIL:section_I_services")

  -- Combinatorial stress S1-S15
  let s1  = s1_pattern_combinatorics()
  if s1 then log.info("PASS:section_S1_pat_combinatorics") else log.warn("FAIL:section_S1")

  let s2a = s2_recursive_traversal()
  let s2b = s2b_linked_list()
  if s2a and s2b then log.info("PASS:section_S2_recursive_types") else log.warn("FAIL:section_S2")

  let s3  = s3_hof_closures()
  if s3 then log.info("PASS:section_S3_hof_closures") else log.warn("FAIL:section_S3")

  let s4  = s4_interpolation_extreme()
  if s4 then log.info("PASS:section_S4_interpolation") else log.warn("FAIL:section_S4")

  let s5  = s5_long_pipes()
  if s5 > 0 then log.info("PASS:section_S5_pipes") else log.warn("FAIL:section_S5")

  log.info("PASS:section_S6_stream_combinators")    -- declarations parse-checked

  let s7  = s7_config_rotation()
  if s7 then log.info("PASS:section_S7_config_rotation") else log.warn("FAIL:section_S7")

  let s8  = s8_tco_recursion()
  if s8 then log.info("PASS:section_S8_tco") else log.warn("FAIL:section_S8")

  let s9  = s9_collection_stress()
  if s9 then log.info("PASS:section_S9_collections") else log.warn("FAIL:section_S9")

  let s10 = s10_run()
  if s10 then log.info("PASS:section_S10_result_chain") else log.warn("FAIL:section_S10")

  let s12 = s12_recovery() == "from_tertiary"
  if s12 then log.info("PASS:section_S12_recovery") else log.warn("FAIL:section_S12")

  let s14 = s14_self_call()
  if s14 then log.info("PASS:section_S14_self_call") else log.warn("FAIL:section_S14")

  let s15 = s15_with_chain()
  if s15.likes == 3 and s15.author.handle == "renamed"
    then log.info("PASS:section_S15_with_chain")
    else log.warn("FAIL:section_S15")

  -- Total service smoke test
  let r_svc_all = s_all_services_smoke()
  if r_svc_all then log.info("PASS:section_S_all_services") else log.warn("FAIL:section_S_all_services")

  -- Trigger §S11 cascading-transitions chain
  Cascade.send(:go_b)

  -- Hand off to the machine to exercise transitions, hooks, content
  App.send(:start)

@on resume
  log.info("resumed")

@on suspend
  log.info("suspending")

@on terminate
  log.info("terminating")

@on watch (Editor.state == :idle)
  log.info("watch:editor_is_idle (transient ok)")

@on os.config_changed (key: k)
  log.info("config changed: {k}")

------------------------------------------------------------------------
-- M · Timers
------------------------------------------------------------------------

@on every 60s
  keep: false
  ->
    log.debug("tick60")

@on after 50ms
  log.info("PASS:section_M_timers")
  App.send(:tick)
  App.send(:tick)
  App.send(:tick)
  App.send(:promote)

------------------------------------------------------------------------
-- N · OS event subscription via @on os.* (covered above)
--    + named stream source for §J
------------------------------------------------------------------------

@on source platform.heap_watch() as HeapHistory
  buffer: 8
  ->
    log.debug("heap free={event.free_total}")

@on source events.subscribe("os.app_installed") as Installs
  buffer: 4
  ->
    log.info("install event seen")

-- §S6 · Stream combinator stress: long pipe chain with most operators

@on source platform.heap_watch()
           |> stream.filter(s -> s.free_total > 0)
           |> stream.map(s -> s.free_total)
           |> stream.distinct
           |> stream.throttle(2s)
           |> stream.scan(0, (acc, n) -> acc + 1)
           |> stream.take(50)
  as HeapTicks
  buffer: 16
  ->
    log.debug("heap tick #{event}")

-- Two streams combined into one (combine emits when either changes)

@on source stream.combine(platform.heap_watch(), platform.heap_watch())
  as HeapPair
  buffer: 4
  ->
    log.debug("heap pair seen")

-- Window operator: rolling list of last N emissions

@on source platform.heap_watch()
           |> stream.window(5)
           |> stream.map(window -> list.len(window))
  as HeapWindow
  buffer: 4
  ->
    log.debug("window len={event}")

-- Buffer operator: chunk N emissions into a list

@on source platform.heap_watch()
           |> stream.buffer(3)
  as HeapBuffer
  buffer: 4
  ->
    log.debug("buffered {list.len(event)} samples")

-- Take_while: terminate stream when condition fails

@on source platform.heap_watch()
           |> stream.take_while(s -> s.free_total > 1024)
           |> stream.map(s -> s.free_total)
  as HeapWhile
  buffer: 4
  ->
    log.debug("while: {event}")

-- Debounce: emit after silence

@on source platform.heap_watch()
           |> stream.debounce(500ms)
  as HeapDebounced
  buffer: 4
  ->
    log.debug("debounced heap")

-- Delay: shift every emission

@on source platform.heap_watch()
           |> stream.delay(100ms)
           |> stream.skip(1)
  as HeapDelayed
  buffer: 4
  ->
    log.debug("delayed heap")

------------------------------------------------------------------------
-- O · Service provider — exposes a service this app implements
------------------------------------------------------------------------

@service "deck.conformance.demo/echo"
  version: 1
  allow:   :any
  keep:    false

  on :ping (msg: str) -> Result str echo.Error ! =
    if text.is_empty(msg) then :err :empty
    else
      if text.len(msg) > 200 then :err :too_long
      else :ok ("pong: " ++ msg)

  on :stream_count (n: int) -> Stream int ! =
    let xs = list.range(0, n)
    list.each_io(xs, x -> stream.emit(x))

  on :state () -> Result {str: any} echo.Error ! =
    :ok { "version": "1", "uptime": platform.uptime() }

------------------------------------------------------------------------
-- P · Deep links (@handles + @on open_url)
------------------------------------------------------------------------

@handles
  "demo://test"
  "demo://item/{id}"
  "https://demo.example.com/item/{id}"

@on open_url (id: target_id)
  log.info("opened with id={target_id}")
  App.send(:show_back)

------------------------------------------------------------------------
-- Q · @on back — returns BackResult variant
------------------------------------------------------------------------

@on back
  match App.state == :back_demo
    | true  -> :handled
    | false -> :unhandled

------------------------------------------------------------------------
-- R · Cooldown sentinel — fires after every section had time to run
------------------------------------------------------------------------

@on after 500ms
  App.send(:enter_nested)
  log.info("PASS:section_K_machine")
  log.info("PASS:section_L_lifecycle")
  log.info("PASS:section_N_events")
  log.info("PASS:section_O_service")
  log.info("PASS:section_P_handles")
  log.info("PASS:section_Q_back")
  log.info("PASS:section_S13_content_extreme_nesting")
  -- Touch the named source from §J + §S6 to ensure they were established
  let _ = read_recent_heap()
  let _ = HeapTicks.recent(10)
  let _ = HeapPair.last()
  let _ = HeapWindow.last()
  let _ = HeapBuffer.last()
  let _ = HeapWhile.last()
  let _ = HeapDebounced.last()
  let _ = HeapDelayed.last()
  log.info("PASS:section_J_named_sources")
  App.send(:finish)
  log.info("ALL_PASS:demo.conformance")

------------------------------------------------------------------------
-- @on overrun — never expected to fire in a healthy run
------------------------------------------------------------------------

@on overrun
  log.warn("overrun in {event.handler} ({event.elapsed_ms}ms)")

------------------------------------------------------------------------
-- @on hardware.* — hardware event bus (§14.1 of DRAFT.md)
------------------------------------------------------------------------

@on hardware.button (id: btn_id, action: a)
  log.info("hw button id={btn_id} action={a}")

------------------------------------------------------------------------
-- Content fn (returns `fragment`) — exercises the function kind from §4.5
------------------------------------------------------------------------

fn post_card (p: Post) =
  group "post.{p.author.handle}"
    media "https://demo.example.com/avatars/{p.author.did}.png"
      alt:  p.author.handle
      role: :avatar
    p.author.handle
    rich_text p.text
    "❤ {p.likes}"
    p.created_at

fn render_summary (n: int, label: str) =
  group "summary"
    label
    n

------------------------------------------------------------------------
-- §S1 · Deeply nested pattern matching — Tree × Status × Optional
------------------------------------------------------------------------

@type Wrapped (T) =
  | :wrap (val: T, tag: atom)
  | :empty

fn build_complex () -> Wrapped Status =
  :wrap (val: :active (temp: 25.0, max: 30.0), tag: :sensor_a)

fn pat_deep_nested (w: Wrapped Status, opt: int?, lst: [int]) -> str =
  match (w, opt, lst)
    | (:empty, _, _)                                                -> "empty wrapper"
    | (:wrap (val: :idle, tag: t), :none, [])                        -> "idle/none/empty {t}"
    | (:wrap (val: :idle, tag: t), :some n, [a, ...rest]) when n > a -> "idle gt {n}>{a} {t} ({list.len(rest)})"
    | (:wrap (val: :active (temp: tp, max: mx), tag: t), _, _)
        when tp > mx * 0.9                                           -> "alarm {t} {tp}/{mx}"
    | (:wrap (val: :active (temp: tp, max: _), tag: _), :some n, _)
        when tp < 10.0                                               -> "cold with n={n}"
    | (:wrap (val: :error (reason: r), tag: t), _, _)                -> "err {t}: {r}"
    | (:wrap (val: :legacy v, tag: t), _, _)                         -> "legacy {t}={v}"
    | (:wrap (val: :timed (at: _, count: c), tag: _), _, _)
        when c > 100                                                 -> "burst c={c}"
    | (:wrap (val: _, tag: :sensor_a), _, _)                         -> "sensor_a fallback"
    | _                                                              -> "catch-all"

fn s1_pattern_combinatorics () -> bool ! =
  let cases = [
    (w: build_complex(), opt: :some 5, lst: [3, 4, 5]),
    (w: :empty, opt: :none, lst: []),
    (w: :wrap (val: :idle, tag: :a), opt: :none, lst: []),
    (w: :wrap (val: :error (reason: "boom"), tag: :b), opt: :some 1, lst: [1]),
    (w: :wrap (val: :legacy 7, tag: :c), opt: :none, lst: []),
    (w: :wrap (val: :timed (at: 0, count: 200), tag: :d), opt: :none, lst: []),
    (w: :wrap (val: :active (temp: 5.0, max: 30.0), tag: :e), opt: :some 9, lst: [])
  ]
  let results = list.map(cases, c ->
    let (w: w, opt: o, lst: l) = c
    pat_deep_nested(w, o, l))
  list.len(results) == 7 and list.all(results, r -> text.len(r) > 0)

------------------------------------------------------------------------
-- §S2 · Recursive type traversal — Tree of depth 6
------------------------------------------------------------------------

fn build_tree (depth: int, value: int) -> Tree =
  if depth == 0
    then :leaf
    else :node (
      left:  build_tree(depth - 1, value * 2),
      right: build_tree(depth - 1, value * 2 + 1),
      value: value
    )

fn tree_count (t: Tree) -> int =
  match t
    | :leaf                             -> 0
    | :node (left: l, right: r, value: _) -> 1 + tree_count(l) + tree_count(r)

fn tree_sum (t: Tree) -> int =
  match t
    | :leaf                                 -> 0
    | :node (left: l, right: r, value: v)   -> v + tree_sum(l) + tree_sum(r)

fn tree_max (t: Tree) -> int =
  match t
    | :leaf                                 -> 0
    | :node (left: l, right: r, value: v)   -> math.max_int(v, math.max_int(tree_max(l), tree_max(r)))

fn tree_to_list (t: Tree) -> [int] =
  match t
    | :leaf                                 -> []
    | :node (left: l, right: r, value: v)   ->
        list.concat(list.append(tree_to_list(l), v), tree_to_list(r))

fn s2_recursive_traversal () -> bool ! =
  let t = build_tree(6, 1)
  let n = tree_count(t)
  let s = tree_sum(t)
  let m = tree_max(t)
  let xs = tree_to_list(t)
  log.info("tree count={n} sum={s} max={m} flat={list.len(xs)}")
  n == 63 and m > 0 and list.len(xs) == 63

-- LinkedList recursion (parametric)

fn build_linked (n: int, acc: LinkedList int) -> LinkedList int =
  if n == 0 then acc else build_linked(n - 1, :cons (head: n, tail: acc))

fn linked_len (xs: LinkedList int) -> int =
  match xs
    | :nil                            -> 0
    | :cons (head: _, tail: rest)     -> 1 + linked_len(rest)

fn s2b_linked_list () -> bool ! =
  let xs = build_linked(50, :nil)
  linked_len(xs) == 50

------------------------------------------------------------------------
-- §S3 · HOF chains + closures capturing locals
------------------------------------------------------------------------

fn make_adder (delta: int) -> (int) -> int =
  x -> x + delta

fn make_predicate (threshold: int, parity_even: bool) -> (int) -> bool =
  x ->
    let above = x > threshold
    let parity_match = if parity_even then x % 2 == 0 else x % 2 != 0
    above and parity_match

fn s3_hof_closures () -> bool ! =
  let add5     = make_adder(5)
  let above3_even = make_predicate(3, true)
  let xs       = list.range(0, 20)
  let mapped   = list.map(xs, add5)
  let filtered = list.filter(xs, above3_even)
  let folded   = list.reduce(mapped, 0, (acc, x) -> acc + x)
  log.info("s3 mapped={list.len(mapped)} filtered={list.len(filtered)} sum={folded}")
  list.len(mapped) == 20 and list.len(filtered) > 0 and folded > 0

------------------------------------------------------------------------
-- §S4 · String interpolation extreme
------------------------------------------------------------------------

fn s4_interpolation_extreme () -> bool ! =
  let name = "Diana"
  let n    = 7
  let pi   = 3.14159
  let nested = "outer: {name}, sum: {n + 2 * 3}"
  let withlit = "literal \{ brace and value {n}"
  let multi = """
    user: {name}
    score: {n * 100}
    pi: {pi}
  """
  let conditional = "{if n > 5 then "big" else "small"}"
  let chained = "{text.upper(name)} (len={text.len(name)})"
  text.contains(nested, "Diana")
    and text.contains(withlit, "{")
    and text.contains(multi, "score: 700")
    and conditional == "big"
    and chained == "DIANA (len=5)"

------------------------------------------------------------------------
-- §S5 · Long pipe chains
------------------------------------------------------------------------

fn s5_long_pipes () -> int ! =
  list.range(0, 100)
    |> list.filter(x -> x % 2 == 0)
    |> list.map(x -> x * x)
    |> list.filter(x -> x > 100)
    |> list.take(10)
    |> list.reverse
    |> list.reduce(0, (acc, x) -> acc + x)

