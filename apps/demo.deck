  let _ = ok_or_known_err("media_audio.play_queue",    media_audio.play_queue(["/sd/x.wav"]))
  let _ = ok_or_known_err("media_audio.enqueue",       media_audio.enqueue("/sd/y.wav"))
  let _ = ok_or_known_err("media_audio.skip_next",     media_audio.skip_next())
  let _ = ok_or_known_err("media_audio.skip_previous", media_audio.skip_previous())
