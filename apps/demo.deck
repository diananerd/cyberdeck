-- §S6 · Stream combinator stress — exercised in @on source below
------------------------------------------------------------------------

-- §S6 declarations live near other @on source blocks (see Heap pipeline below)

------------------------------------------------------------------------
-- §S7 · Config rotation through every declared type
------------------------------------------------------------------------

fn s7_config_rotation () -> bool ! =
  let r1 = config.set(:greeting, "rotated") |> result.is_ok
  let r2 = config.set(:retry_count, 5) |> result.is_ok
  let r3 = config.set(:pi_estimate, 3.14159) |> result.is_ok
  let r4 = config.set(:enabled, false) |> result.is_ok
  let r5 = config.set(:theme, :dark) |> result.is_ok
  let r6 = config.set(:sync_every, 10m) |> result.is_ok
  let r7 = config.set(:cache_quota, 128KB) |> result.is_ok
  let r8 = config.set(:api_token, :some "tok_xyz") |> result.is_ok
  let r9 = config.set(:pinned_ids, ["a", "b", "c"]) |> result.is_ok
  let r10 = config.set(:bookmarks, { "home": "/", "blog": "/posts" }) |> result.is_ok
  let r11 = config.set(:history, config.history with { "demo": time.now() }) |> result.is_ok
  -- Out-of-range write should fail predictably:
  let r12 = match config.set(:retry_count, 999)
              | :err :out_of_range -> true
              | _                  -> false
  r1 and r2 and r3 and r4 and r5 and r6 and r7 and r8 and r9 and r10 and r11 and r12

------------------------------------------------------------------------
-- §S8 · TCO / deep recursion
------------------------------------------------------------------------

fn count_down_tco (n: int) -> int =
  if n == 0 then 0 else count_down_tco(n - 1)

fn sum_down_tco (n: int, acc: int) -> int =
  if n == 0 then acc else sum_down_tco(n - 1, acc + n)

fn even_p (n: int) -> bool =
  if n == 0 then true else odd_p(n - 1)

fn odd_p (n: int) -> bool =
  if n == 0 then false else even_p(n - 1)

fn s8_tco_recursion () -> bool ! =
  let r1 = count_down_tco(500)
  let r2 = sum_down_tco(100, 0)
  let r3 = even_p(200)
  let r4 = odd_p(201)
  log.info("s8 r1={r1} r2={r2} r3={r3} r4={r4}")
  r1 == 0 and r2 == 5050 and r3 and r4

------------------------------------------------------------------------
-- §S9 · Map / list size stress
------------------------------------------------------------------------

fn s9_collection_stress () -> bool ! =
  let big_list = list.range(0, 200)
  let mapped   = list.map(big_list, x -> x * 3)
  let filtered = list.filter(mapped, x -> x % 2 == 0)
  let summed   = list.reduce(filtered, 0, (a, b) -> a + b)
  let big_map  = list.reduce(big_list, map.empty(), (acc, n) -> map.set(acc, "k_{n}", n))
  let map_sum  = list.reduce(map.values(big_map), 0, (a, b) -> a + b)
  let chunked  = list.chunks(big_list, 7)
  log.info("s9 sum={summed} map_sum={map_sum} chunks={list.len(chunked)}")
  list.len(big_list) == 200
    and list.len(mapped) == 200
    and list.len(filtered) == 100
    and summed > 0
    and map.len(big_map) == 200
    and map_sum > 0
    and list.len(chunked) > 25

------------------------------------------------------------------------
-- §S10 · Result / Option chain with map_err at every layer
------------------------------------------------------------------------

@errors layerA
  :unavailable
  :permission_denied
  :service_unavailable
  :timeout
  :a_failed

@errors layerB
  :unavailable
  :permission_denied
  :service_unavailable
  :timeout
  :b_failed

@errors layerC
  :unavailable
  :permission_denied
  :service_unavailable
  :timeout
  :c_failed

@errors stack
  :unavailable
  :permission_denied
  :service_unavailable
  :timeout
  :downstream

fn op_a () -> Result int layerA.Error ! =
  :ok 10

fn op_b (n: int) -> Result int layerB.Error ! =
  if n > 0 then :ok (n * 2) else :err :b_failed

fn op_c (n: int) -> Result int layerC.Error ! =
  if n < 100 then :ok (n + 1) else :err :c_failed

fn s10_chain () -> Result int stack.Error ! =
  let a = op_a() |> result.map_err(_ -> :downstream)?
  let b = op_b(a) |> result.map_err(_ -> :downstream)?
  let c = op_c(b) |> result.map_err(_ -> :downstream)?
  :ok c

fn s10_run () -> bool ! =
  match s10_chain()
    | :ok 21  -> true
    | :ok n   -> log.warn("s10 unexpected {n}")
                 false
    | :err _  -> false

------------------------------------------------------------------------
-- §S12 · Error recovery chain (5-layer fallback)
------------------------------------------------------------------------

fn fetch_primary () -> Result str demo.Error ! = :err :unsupported
fn fetch_secondary () -> Result str demo.Error ! = :err :over_limit
fn fetch_tertiary () -> Result str demo.Error ! = :ok "from_tertiary"
fn fetch_default () -> str = "static_default"

fn s12_recovery () -> str ! =
  match fetch_primary()
    | :ok v  -> v
    | :err _ ->
        match fetch_secondary()
          | :ok v  -> v
          | :err _ ->
              match fetch_tertiary()
                | :ok v  -> v
                | :err _ -> fetch_default()

------------------------------------------------------------------------
-- §S14 · Service self-call chain
------------------------------------------------------------------------

fn s14_self_call () -> bool ! =
  let r1 = self_echo.ping("hello")
  let r2 = self_echo.ping("")
  let r3 = self_echo.state()
  let ok1 = match r1 | :ok s -> text.starts(s, "pong: ") | :err _ -> false
  let ok2 = match r2 | :err :empty -> true | _ -> false
  let ok3 = match r3 | :ok m -> map.has(m, "version") | :err _ -> false
  ok1 and ok2 and ok3

------------------------------------------------------------------------
-- §S15 · with{} chain on nested records
------------------------------------------------------------------------

fn s15_with_chain () -> Post =
  let p0 = sample_post()
  let a1 = p0.author with { followers: 100 }
  let a2 = a1 with { handle: "renamed" }
  let p1 = p0 with { author: a2 }
  let p2 = p1 with { likes: 1, text: "rev1" }
  let p3 = p2 with { likes: 2 } with { likes: 3 } with { text: "rev3" }
  p3

------------------------------------------------------------------------
-- §S_SERVICES · Smoke-test EVERY declared service (≥1 method per service).
-- Errors :unavailable / :permission_denied are tolerated and counted as
-- successful invocation — the goal is parse + dispatch coverage, not
-- behavioural correctness on a stub platform.
------------------------------------------------------------------------

@private fn ok_or_known_err (label: str, r: any) -> bool ! =
  match r
    | :ok _                       -> log.debug("{label}: ok")
                                     true
    | :err :unavailable           -> log.debug("{label}: unavailable (ok)")
                                     true
    | :err :permission_denied     -> log.debug("{label}: permission_denied (ok)")
                                     true
    | :err :service_unavailable   -> log.debug("{label}: service_unavailable (ok)")
                                     true
    | :err :timeout               -> log.debug("{label}: timeout (ok)")
                                     true
    | :err e                      -> log.debug("{label}: err {e} (ok)")
                                     true

fn s_all_services_smoke () -> bool ! =
  -- Tier 1: storage
  let _ = ok_or_known_err("fs.exists",   :ok (fs.exists("/sd/demo/x")))
  let _ = ok_or_known_err("fs.size",     fs.size("/sd/demo/x"))
  let _ = ok_or_known_err("fs.modified", fs.modified("/sd/demo/x"))
  let _ = ok_or_known_err("fs.list",     fs.list("/sd/demo"))
  let _ = ok_or_known_err("fs.read",     fs.read("/sd/demo/x"))
  let _ = ok_or_known_err("fs.write",    fs.write("/sd/demo/probe.txt", "hi"))
  let _ = ok_or_known_err("fs.delete",   fs.delete("/sd/demo/probe.txt"))
  let _ = ok_or_known_err("fs.mkdir",    fs.mkdir("/sd/demo/sub"))
  let _ = ok_or_known_err("fs.rmdir",    fs.rmdir("/sd/demo/sub"))
  let _ = ok_or_known_err("fs.rename",   fs.rename("/sd/demo/a", "/sd/demo/b"))

  let _ = ok_or_known_err("nvs.set_str",   nvs.set_str("k_str", "v"))
  let _ = ok_or_known_err("nvs.get_str",   nvs.get_str("k_str"))
  let _ = ok_or_known_err("nvs.set_int",   nvs.set_int("k_int", 42))
  let _ = ok_or_known_err("nvs.get_int",   nvs.get_int("k_int"))
  let _ = ok_or_known_err("nvs.set_float", nvs.set_float("k_float", 1.5))
  let _ = ok_or_known_err("nvs.get_float", nvs.get_float("k_float"))
  let _ = ok_or_known_err("nvs.set_bool",  nvs.set_bool("k_bool", true))
  let _ = ok_or_known_err("nvs.get_bool",  nvs.get_bool("k_bool"))
  let _ = ok_or_known_err("nvs.set_bytes", nvs.set_bytes("k_b", bytes.from_str("hi", :utf8)))
  let _ = ok_or_known_err("nvs.get_bytes", nvs.get_bytes("k_b"))
  let _ = ok_or_known_err("nvs.exists",    :ok (nvs.exists("k_str")))
  let _ = ok_or_known_err("nvs.keys",      nvs.keys())
  let _ = ok_or_known_err("nvs.delete",    nvs.delete("k_str"))

  let _ = ok_or_known_err("cache.set",       cache.set("hot", "data", 30s))
  let _ = ok_or_known_err("cache.get",       :ok (cache.get("hot")))
  let _ = ok_or_known_err("cache.set_bytes", cache.set_bytes("b_hot", bytes.from_str("x", :utf8), 30s))
  let _ = ok_or_known_err("cache.get_bytes", :ok (cache.get_bytes("b_hot")))
  let _ = ok_or_known_err("cache.ttl",       :ok (cache.ttl("hot")))
  cache.delete("hot")
  cache.clear()

  -- Tier 2: network
  let _ = ok_or_known_err("http.get",    http.get("/probe", :none))
  let _ = ok_or_known_err("http.post",   http.post("/probe", :json { "x": 1 }, :none))
  let _ = ok_or_known_err("http.put",    http.put("/probe", :str "x", :none))
  let _ = ok_or_known_err("http.patch",  http.patch("/probe", :form { "k": "v" }, :none))
  let _ = ok_or_known_err("http.delete", http.delete("/probe", :none))
  let _ = ok_or_known_err("ws.connect",  ws.connect("wss://demo.example.com/socket", :none))
  let _ = ok_or_known_err("wifi.status", :ok (wifi.status()))
  let _ = ok_or_known_err("wifi.connect", wifi.connect("Demo", :none))
  let _ = ok_or_known_err("wifi.disconnect", wifi.disconnect())
  let _ = ok_or_known_err("wifi.forget", wifi.forget("Demo"))
  let _ = ok_or_known_err("wifi.set_enabled", wifi.set_enabled(true))
  let _ = ok_or_known_err("ble.connect", ble.connect("00:11:22:33:44:55"))

  -- Tier 3: system
  log.info("platform.device_id={platform.device_id()}")
  log.info("platform.model={platform.model()}")
