  let _ = ok_or_known_err("media_audio.resume",        media_audio.resume())
  let _ = ok_or_known_err("media_audio.stop",          media_audio.stop())
  let _ = ok_or_known_err("media_audio.seek",          media_audio.seek(0ms))
  let _ = ok_or_known_err("media_audio.state",         :ok (media_audio.state()))

  let _ = ok_or_known_err("oauth.start_flow",  oauth.start_flow("demo", ["read"]))
  let _ = ok_or_known_err("oauth.token",       :ok (oauth.token("demo")))
  let _ = ok_or_known_err("oauth.refresh",     oauth.refresh("demo"))
  let _ = ok_or_known_err("oauth.revoke",      oauth.revoke("demo"))
  let _ = ok_or_known_err("oauth.providers",   :ok (oauth.providers()))

  let _ = ok_or_known_err("data_cache.get",        :ok (data_cache.get("k")))
  let _ = ok_or_known_err("data_cache.set",        data_cache.set("k", 1, CacheOpts { ttl: 1m, content_type: :none }))
  let _ = ok_or_known_err("data_cache.delete",     :ok (data_cache.delete("k")))
  let _ = ok_or_known_err("data_cache.invalidate", data_cache.invalidate("k*"))

  -- Cross-tier: share service (app-provided)
  let _ = ok_or_known_err("share.share",            share.share(ShareContent {
                                                       kind: :url,
                                                       title: :some "Demo",
                                                       body:  :none,
                                                       url:   :some "https://demo.example.com",
                                                       image_ref: :none,
                                                       file_path: :none
                                                     }))
  let _ = ok_or_known_err("share.supported_kinds", share.supported_kinds())

